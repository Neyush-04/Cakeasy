rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Reusable primitive validators
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Validation Blueprint for MenuItem
    function isValidMenuItem(data) {
      return data.keys().hasAll(['id', 'name', 'description', 'priceRange', 'category', 'image', 'popularFlavors'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.description is string && data.description.size() <= 500
        && data.priceRange is string && data.priceRange.size() <= 50
        && (data.category == 'bento' || data.category == 'celebration' || data.category == 'wedding' || data.category == 'cupcakes')
        && data.image is string && data.image.size() <= 1000
        && data.popularFlavors is list && data.popularFlavors.size() <= 20;
    }

    // Validation Blueprint for Order Inquiries
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'customer', 'cake', 'status', 'eta'])
        && data.keys().size() >= 5
        && data.id is string && data.id.size() <= 128
        && data.customer is string && data.customer.size() <= 100
        && data.cake is string && data.cake.size() <= 200
        && (data.status == 'received' || data.status == 'baking' || data.status == 'piping' || data.status == 'checked' || data.status == 'dispatched')
        && data.eta is string && data.eta.size() <= 100;
    }

    // Validation Blueprint for Instagram Posts
    function isValidInstagramPost(data) {
      return data.keys().hasAll(['id', 'imageUrl', 'caption', 'likes', 'commentsCount', 'date', 'comments'])
        && data.keys().hasOnly(['id', 'imageUrl', 'images', 'caption', 'likes', 'commentsCount', 'date', 'comments'])
        && data.id is string && data.id.size() <= 128
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && (!('images' in data.keys()) || (data.images is list && data.images.size() <= 20))
        && data.caption is string && data.caption.size() <= 1000
        && data.likes is number
        && data.commentsCount is number
        && data.date is string && data.date.size() <= 100
        && data.comments is list;
    }

    // Products Catalog Match Rules
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(productId) && isValidMenuItem(incoming());
      allow delete: if isAdmin() && isValidId(productId);
    }

    // Order Tracking Match Rules
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin() && isValidId(orderId) && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['id', 'customer', 'cake', 'status', 'eta'])
      );
      allow delete: if isAdmin() && isValidId(orderId);
    }

    // General Studio Operations Settings Match Rules
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingsId);
    }

    // Promo Coupons Match Rules
    match /coupons/{couponId} {
      allow read, write: if isAdmin() && isValidId(couponId);
    }

    // Instagram Posts Match Rules
    match /instagram_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(postId) && isValidInstagramPost(incoming());
      allow delete: if isAdmin() && isValidId(postId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
